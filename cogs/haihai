import discord
from discord.ext import commands

class HiCog(commands.Cog):
    def __init__(self, bot):
        self.bot = bot

    @commands.command(name="hi")
    async def hi(self, ctx):
        """シンプルな挨拶コマンド"""
        await ctx.send(f"こんにちは！ {ctx.author.mention} 👋")

async def setup(bot):
    await bot.add_cog(HiCog(bot))
